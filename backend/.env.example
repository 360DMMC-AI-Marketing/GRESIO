PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/gresio
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:3000
SUPER_ADMIN_URL=

# Email — Azure Communication Services (highest priority)
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_SENDER_EMAIL=

# Email — Microsoft Graph (fallback)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=
GRAPH_SENDER_EMAIL=

# Email — SMTP (last fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Integrations
GITHUB_TOKEN=
CLICKUP_API_KEY=
DEFAULT_TEAMS_TEAM_ID=

# Cluster mode (set CLUSTER_MODE=true to enable)
CLUSTER_MODE=false
CLUSTER_WORKERS=
